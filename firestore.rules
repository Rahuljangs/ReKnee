rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Messages subcollection — user can read all, write only their own messages
      match /messages/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }

      // Daily logs — user can read/write their own logs
      match /daily_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // DVT alerts — user can read, only server can write
      match /dvt_alerts/{alertId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
