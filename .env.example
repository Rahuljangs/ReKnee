# Firebase (download from Firebase Console)
# Place google-services.json in project root for Android
# Place GoogleService-Info.plist in project root for iOS

# Google Sign-In Web Client ID (from Firebase Console > Authentication > Sign-in method > Google)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Gemini API Key (set as Firebase secret, NOT in client code)
# Run: firebase functions:secrets:set GEMINI_API_KEY
GEMINI_API_KEY=your-gemini-api-key

# RevenueCat API Keys (from RevenueCat dashboard)
REVENUECAT_ANDROID_API_KEY=your-revenuecat-android-key
REVENUECAT_IOS_API_KEY=your-revenuecat-ios-key

# EAS Project ID (run: npx eas init)
EAS_PROJECT_ID=your-eas-project-id
